### Фаза 4: Frontend Components

#### 4.1 Создать `frontend/src/components/CodeEditor.jsx`

```jsx
import React, { useState } from 'react';

function CodeEditor({ courseId, studentId, task, tests, onSubmit }) {
  const [code, setCode] = useState('');
  const [loading, setLoading] = useState(false);
  const [results, setResults] = useState(null);
  const [showTests, setShowTests] = useState(false);
  
  const handleSubmit = async () => {
    setLoading(true);
    try {
      const response = await fetch(
        `${API_BASE}/student/${studentId}/courses/${courseId}/submit-code`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        }
      );
      
      const data = await response.json();
      setResults(data);
      setShowTests(true);
    } catch (error) {
      console.error('Submission error:', error);
    } finally {
      setLoading(false);
    }
  };
  
  return (
    <div className="code-editor-container">
      <div className="task-panel">
        <h3>Задание:</h3>
        <p>{task}</p>
        
        <h4>Примеры тестов:</h4>
        <ul>
          {tests.map((test, i) => (
            <li key={i}>
              Input: {test.input} → Expected: {test.expected_output}
            </li>
          ))}
        </ul>
      </div>
      
      <div className="editor-panel">
        <textarea
          value={code}
          onChange={(e) => setCode(e.target.value)}
          placeholder="Пишите код здесь..."
          className="code-textarea"
        />
        
        <button 
          onClick={handleSubmit}
          disabled={loading || !code.trim()}
          className="submit-button"
        >
          {loading ? 'Проверяю...' : 'Отправить на проверку'}
        </button>
      </div>
      
      {results && (
        <div className="results-panel">
          <h3>{results.success ? '✅ Все тесты пройдены!' : '❌ Некоторые тесты не прошли'}</h3>
          {results.results.map((result, i) => (
            <div key={i} className={`test-result ${result.passed ? 'passed' : 'failed'}`}>
              <p>Тест {result.test_number}: {result.passed ? '✅' : '❌'}</p>
              <p>Input: {result.input}</p>
              <p>Expected: {result.expected}</p>
              <p>Actual: {result.actual || result.error}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

export default CodeEditor;
```

