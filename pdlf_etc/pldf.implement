### Фаза 2: Backend API Endpoints

#### 2.1 Endpoints для работы с кодом

**GET /courses/{course_id}/coding** - получить задание и попытки
```python
@app.get("/courses/{course_id}/coding")
def get_coding_task(course_id: int, student_id: Optional[int] = None, db: Session = Depends(get_db)):
    """
    Получить:
    - Описание задания (coding_task)
    - Решение преподавателя (если преподаватель)
    - Тесты (test_cases)
    - Попытки студента (если student_id указан)
    """
    course = db.query(Course).filter(Course.id == course_id).first()
    if not course:
        raise HTTPException(404, "Course not found")
    
    return {
        "id": course.id,
        "title": course.title,
        "task": course.coding_task or "",
        "solution": course.coding_solution or "",  # только для преподавателя
        "tests": json.loads(course.test_cases or "[]"),
        "submissions": [...]  # если student_id указан
    }
```

**POST /student/{student_id}/courses/{course_id}/submit-code** - отправить код на проверку
```python
@app.post("/student/{student_id}/courses/{course_id}/submit-code")
def submit_code(
    student_id: int,
    course_id: int,
    code_data: CodeSubmitRequest,  # {"code": "def factorial(n): ..."}
    db: Session = Depends(get_db)
):
    """
    1. Сохранить код студента в CodeSubmission
    2. Запустить тесты против кода
    3. Вернуть результаты
    """
    student = db.query(User).filter(User.id == student_id, User.role == "student").first()
    course = db.query(Course).filter(Course.id == course_id).first()
    
    if not student or not course:
        raise HTTPException(404, "Not found")
    
    # Запустить тесты
    test_results, is_correct = run_tests(code_data.code, course.test_cases)
    
    # Сохранить в БД
    submission = CodeSubmission(
        student_id=student_id,
        course_id=course_id,
        code=code_data.code,
        is_correct=is_correct,
        test_results=json.dumps(test_results)
    )
    db.add(submission)
    db.commit()
    
    return {
        "success": is_correct,
        "results": test_results,
        "message": "All tests passed!" if is_correct else "Some tests failed"
    }
```

**GET /student/{student_id}/courses/{course_id}/submissions** - история попыток
```python
@app.get("/student/{student_id}/courses/{course_id}/submissions")
def get_submissions(student_id: int, course_id: int, db: Session = Depends(get_db)):
    submissions = db.query(CodeSubmission).filter(
        CodeSubmission.student_id == student_id,
        CodeSubmission.course_id == course_id
    ).order_by(CodeSubmission.created_at.desc()).all()
    
    return [{
        "id": s.id,
        "code": s.code,
        "is_correct": s.is_correct,
        "results": json.loads(s.test_results or "[]"),
        "created_at": s.created_at.isoformat()
    } for s in submissions]
```

#### 2.2 Endpoint для создания/обновления тестов (преподаватель)

**POST /teacher/{teacher_id}/courses/{course_id}/tests/update** - обновить тесты
```python
@app.post("/teacher/{teacher_id}/courses/{course_id}/tests/update")
def update_tests(teacher_id: int, course_id: int, tests_data: TestsUpdateRequest, db: Session = Depends(get_db)):
    """
    Обновить test_cases для курса
    """
    course = db.query(Course).filter(
        Course.id == course_id,
        Course.teacher_id == teacher_id
    ).first()
    
    if not course:
        raise HTTPException(404, "Course not found or not yours")
    
    course.test_cases = json.dumps(tests_data.tests)  # сохранить JSON
    db.commit()
    
    return {"message": "Tests updated"}
```

---

### Фаза 3: Code Execution Engine

#### 3.1 Функция для запуска тестов (`backend/app/utils.py`)

```python
import subprocess
import json
import tempfile
import os

def run_tests(student_code: str, test_cases_json: str) -> tuple[list, bool]:
    """
    Запустить тесты для кода студента
    Возвращает: (результаты тестов, все ли прошли)
    """
    test_cases = json.loads(test_cases_json or "[]")
    results = []
    all_passed = True
    
    # Создать временный файл с кодом студента
    with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:
        f.write(student_code)
        code_file = f.name
    
    try:
        for i, test in enumerate(test_cases):
            test_input = test.get("input", "")
            expected_output = test.get("expected_output", "")
            
            try:
                # Запустить код с input'ом
                result = subprocess.run(
                    ["python", code_file],
                    input=test_input,
                    capture_output=True,
                    text=True,
                    timeout=5  # 5 секунд таймаут
                )
                
                actual_output = result.stdout.strip()
                passed = actual_output == expected_output
                
                if not passed:
                    all_passed = False
                
                results.append({
                    "test_number": i + 1,
                    "input": test_input,
                    "expected": expected_output,
                    "actual": actual_output,
                    "passed": passed,
                    "error": result.stderr if result.returncode != 0 else None
                })
            
            except subprocess.TimeoutExpired:
                all_passed = False
                results.append({
                    "test_number": i + 1,
                    "passed": False,
                    "error": "Timeout: code execution took too long"
                })
            
            except Exception as e:
                all_passed = False
                results.append({
                    "test_number": i + 1,
                    "passed": False,
                    "error": str(e)
                })
    
    finally:
        # Удалить временный файл
        if os.path.exists(code_file):
            os.unlink(code_file)
    
    return results, all_passed
```

⚠️ **Безопасность:** Для production нужно использовать sandboxing (Docker, seccomp, или сервис типа Judge0)

